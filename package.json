{
	"name": "segoya-frontend",
	"version": "1.1.1",
	"author": "VasyS",
	"license": "AGPL-3.0-only",
	"private": true,
	"type": "module",
	"scripts": {
		"api-gen:sync": "pnpx typed-openapi@2.2.3 http://localhost:4174/openapi/bundled.yaml -r zod --include-client false -o src/lib/api/openapi.ts",
		"api-gen:fix": "node src/lib/api/openapi-fix.ts",
		"api-gen": "pnpm run api-gen:sync && pnpm run api-gen:fix",
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview --port 5173 --host",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "pnpm run lint --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report"
	},
	"devDependencies": {
		"@dicebear/collection": "^9.4.2",
		"@dicebear/core": "^9.2.4",
		"@eslint/js": "^9.39.2",
		"@googlemaps/js-api-loader": "^2.1.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@inlang/paraglide-js": "^2.20.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^6.0.0-next.0",
		"@sveltejs/kit": "^3.0.0-next.4",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@types/google.maps": "^3.65.1",
		"@types/jest": "^30.0.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24.10.6",
		"@types/set-cookie-parser": "^2.4.10",
		"@types/yandex-maps": "^2.1.36",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"@vitest/coverage-v8": "^4.1.9",
		"@vitest/eslint-plugin": "^1.6.20",
		"@vitest/ui": "^4.1.9",
		"bits-ui": "^2.18.1",
		"bowser": "^2.14.1",
		"clsx": "^2.1.1",
		"cropperjs": "1.6.2",
		"eslint": "^9.39.2",
		"eslint-import-resolver-vite": "^2.2.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-playwright": "^2.10.4",
		"eslint-plugin-svelte": "^3.19.0",
		"eslint-plugin-testing-library": "^7.16.2",
		"eslint-plugin-unicorn": "^66.0.0",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"jiti": "^2.7.0",
		"jsdom": "^29.1.1",
		"leaflet": "^1.9.4",
		"mode-watcher": "^1.1.0",
		"motion": "^12.40.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"set-cookie-parser": "^2.7.2",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "8.0.16",
		"vitest": "^4.1.9",
		"zod": "^4.4.3"
	},
	"prettier": {
		"useTabs": true,
		"singleQuote": true,
		"trailingComma": "none",
		"printWidth": 100,
		"singleAttributePerLine": true,
		"objectWrap": "preserve",
		"plugins": [
			"prettier-plugin-svelte",
			"prettier-plugin-tailwindcss",
			"@ianvs/prettier-plugin-sort-imports"
		],
		"overrides": [
			{
				"files": "*.svelte",
				"options": {
					"parser": "svelte"
				}
			}
		],
		"svelteSortOrder": "scripts-markup-styles-options",
		"importOrder": [
			"^@core/(.*)$",
			"",
			"^@server/(.*)$",
			"",
			"^$components/(.*)$",
			"",
			"^[./]"
		],
		"importOrderParserPlugins": [
			"typescript",
			"jsx",
			"decorators-legacy"
		],
		"importOrderTypeScriptVersion": "5.8.3",
		"importOrderCaseSensitive": false
	}
}
